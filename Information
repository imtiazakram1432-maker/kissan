  <!-- ===== CALCULATOR SECTION ===== -->
  <div class="section-title">
    <h2>🧮 زمین منافع کیلکولیٹر</h2>
    <p>اپنی زمین کا رقبہ درج کریں اور سالانہ منافع جانیں</p>
    <div class="divider"></div>
  </div>

  <section class="calculator-section">
    <div class="calc-box">

      <!-- header bar -->
      <div class="calc-header">
        <i class="fa-solid fa-calculator"></i>
        <h3>منافع کیلکولیٹر</h3>
        <span>1 ایکڑ = ₨ 60,000 سالانہ</span>
      </div>

      <div class="calc-body">

        <!-- info strip -->
        <div class="rate-info">
          <i class="fa-solid fa-circle-info"></i>
          موجودہ منافع کی شرح: <strong>1 ایکڑ = ₨ 60,000 فی سال</strong> — اپنا رقبہ کسی بھی اکائی میں درج کریں۔
        </div>

        <!-- input row -->
        <div class="input-grid">
          <div class="form-group">
            <label><i class="fa-solid fa-user"></i> مالک کا نام</label>
            <input type="text" id="ownerName" placeholder="  مثال: محمد  " />
          </div>
          <div class="form-group">
            <label><i class="fa-solid fa-map"></i> رقبہ</label>
            <input type="number" id="areaInput" placeholder="0" min="0.1" step="0.5" />
          </div>
          <div class="form-group">
            <label><i class="fa-solid fa-ruler"></i> اکائی</label>
            <select id="unitSelect">
              <option value="acre">ایکڑ (Acre)</option>
              <option value="marla">مرلہ (Marla)</option>
              <option value="kanal">کنال (Kanal)</option>
              <option value="hectare">ہیکٹر (Hectare)</option>
            </select>
          </div>
          <div class="form-group">
            <label><i class="fa-solid fa-calendar"></i> سال</label>
            <input type="number" id="yearsInput" value="1" min="1" max="50" />
          </div>
          <div class="form-group" style="justify-content: flex-end;">
            <label>&nbsp;</label>
            <button class="btn-add" onclick="addEntry()">
              <i class="fa-solid fa-plus"></i> شامل کریں
            </button>
          </div>
        </div>

        <!-- summary cards (hidden until entries exist) -->
        <div class="summary-grid" id="summaryCards" style="display:none">
          <div class="metric-card">
            <div class="metric-label">کل رقبہ (ایکڑ)</div>
            <div class="metric-value" id="smTotalAcres">0</div>
          </div>
          <div class="metric-card">
            <div class="metric-label">سالانہ منافع</div>
            <div class="metric-value gold" id="smAnnual">₨0</div>
          </div>
          <div class="metric-card">
            <div class="metric-label">کل منافع</div>
            <div class="metric-value gold" id="smTotal">₨0</div>
          </div>
          <div class="metric-card">
            <div class="metric-label">ماہانہ اوسط</div>
            <div class="metric-value" id="smMonthly">₨0</div>
          </div>
        </div>

        <!-- table -->
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>#</th>
                <th>مالک کا نام</th>
                <th>رقبہ</th>
                <th>ایکڑ</th>
                <th>سال</th>
                <th>سالانہ منافع</th>
                <th>کل منافع</th>
                <th>حذف</th>
              </tr>
            </thead>
            <tbody id="tableBody">
              <tr class="empty-row">
                <td colspan="8">
                  <i class="fa-solid fa-seedling" style="font-size:1.4rem; color:#86efac; display:block; margin-bottom:6px;"></i>
                  ابھی کوئی اندراج نہیں — اوپر رقبہ درج کریں
                </td>
              </tr>
            </tbody>
            <tfoot id="tableFoot"></tfoot>
          </table>
        </div>

        <!-- clear button -->
        <button class="btn-clear" id="btnClear" style="display:none" onclick="clearAll()">
          <i class="fa-solid fa-trash"></i> سب حذف کریں
        </button>

      </div><!-- /.calc-body -->
    </div><!-- /.calc-box -->
  </section>

  <!-- ===== FOOTER ===== -->
  <footer>
