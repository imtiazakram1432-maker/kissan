<!DOCTYPE html>
<html lang="ur" dir="rtl">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pak Kissan | کسان دوست پلیٹ فارم</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Nastaliq+Urdu:wght@400;600;700&family=Teko:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --green-dark:   #1b4332;
      --green-mid:    #2d6a4f;
      --green-light:  #40916c;
      --green-pale:   #d8f3dc;
      --gold:         #e9c46a;
      --gold-dark:    #c9a227;
      --cream:        #fefae0;
      --brown:        #6b4226;
      --text-dark:    #1a1a1a;
      --text-mid:     #3d3d3d;
      --text-light:   #6b7280;
      --white:        #ffffff;
      --shadow:       0 4px 24px rgba(27,67,50,0.10);
      --shadow-lg:    0 8px 40px rgba(27,67,50,0.16);
      --radius:       12px;
      --radius-lg:    20px;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Noto Nastaliq Urdu', serif;
      background: var(--cream);
      color: var(--text-dark);
      line-height: 1.8;
    }

    /* ── HEADER ── */
    .site-header {
      background: var(--green-dark);
      padding: 0 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 2px 16px rgba(0,0,0,0.18);
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
    }

    .logo-icon {
      font-size: 28px;
      animation: sway 3s ease-in-out infinite;
    }

    @keyframes sway {
      0%, 100% { transform: rotate(-5deg); }
      50%       { transform: rotate(5deg); }
    }

    .logo-text {
      font-family: 'Teko', sans-serif;
      font-size: 26px;
      color: var(--white);
      letter-spacing: 1px;
    }

    .logo-text span { color: var(--gold); }

    .header-tagline {
      font-size: 12px;
      color: var(--green-pale);
      display: none;
    }

    @media (min-width: 640px) { .header-tagline { display: block; } }

    /* ── NAV ── */
    nav {
      background: var(--green-mid);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
      flex-wrap: wrap;
      gap: 8px;
    }

    nav ul {
      list-style: none;
      display: flex;
      gap: 4px;
      flex-wrap: wrap;
    }

    nav ul li a {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 10px 16px;
      color: var(--green-pale);
      text-decoration: none;
      font-family: 'Teko', sans-serif;
      font-size: 16px;
      letter-spacing: 0.5px;
      border-radius: 6px;
      transition: background 0.2s, color 0.2s;
    }

    nav ul li a:hover,
    nav ul li a.active {
      background: var(--green-dark);
      color: var(--gold);
    }

    .social-strip {
      display: flex;
      gap: 8px;
    }

    .social-strip a {
      display: flex;
      align-items: center;
      gap: 5px;
      padding: 6px 12px;
      color: var(--green-pale);
      text-decoration: none;
      font-family: 'Teko', sans-serif;
      font-size: 14px;
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 20px;
      transition: all 0.2s;
    }

    .social-strip a:hover { background: var(--gold); color: var(--green-dark); border-color: var(--gold); }

    /* ── HERO ── */
    .hero {
      background: linear-gradient(135deg, var(--green-dark) 0%, var(--green-mid) 60%, #52b788 100%);
      color: var(--white);
      text-align: center;
      padding: 5rem 2rem 4rem;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Ccircle cx='30' cy='30' r='4'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
      pointer-events: none;
    }

    .hero h1 {
      font-size: clamp(1.6rem, 5vw, 3rem);
      font-weight: 700;
      margin-bottom: 1rem;
      position: relative;
    }

    .hero p {
      font-size: clamp(0.95rem, 2vw, 1.15rem);
      color: var(--green-pale);
      max-width: 600px;
      margin: 0 auto 2rem;
      position: relative;
    }

    .hero-badges {
      display: flex;
      justify-content: center;
      gap: 12px;
      flex-wrap: wrap;
      position: relative;
    }

    .badge {
      display: flex;
      align-items: center;
      gap: 8px;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.22);
      backdrop-filter: blur(8px);
      padding: 8px 18px;
      border-radius: 30px;
      font-size: 0.9rem;
      color: var(--white);
      transition: transform 0.2s, background 0.2s;
    }

    .badge:hover { transform: translateY(-2px); background: rgba(255,255,255,0.2); }

    .hero-scroll {
      margin-top: 2.5rem;
      font-size: 22px;
      color: var(--gold);
      animation: bounce 1.8s ease-in-out infinite;
      position: relative;
    }

    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50%       { transform: translateY(6px); }
    }

    /* ── FEATURES ── */
    .features {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 20px;
      padding: 3rem 2rem;
      max-width: 1000px;
      margin: 0 auto;
    }

    .feature-card {
      background: var(--white);
      border: 1px solid #d1fae5;
      border-radius: var(--radius-lg);
      padding: 2rem 1.5rem;
      text-align: center;
      box-shadow: var(--shadow);
      transition: transform 0.25s, box-shadow 0.25s;
      cursor: default;
    }

    .feature-card:hover {
      transform: translateY(-5px);
      box-shadow: var(--shadow-lg);
    }

    .feature-card .icon { font-size: 2.5rem; margin-bottom: 10px; }

    .feature-card h4 {
      color: var(--green-dark);
      font-size: 1rem;
      font-weight: 600;
    }

    /* ── SECTION TITLE ── */
    .section-title {
      text-align: center;
      padding: 1rem 2rem 0;
    }

    .section-title h2 {
      font-size: clamp(1.3rem, 3vw, 1.9rem);
      color: var(--green-dark);
      font-weight: 700;
    }

    .section-title p {
      color: var(--text-light);
      font-size: 0.95rem;
      margin-top: 6px;
    }

    .divider {
      width: 60px;
      height: 4px;
      background: var(--gold);
      border-radius: 2px;
      margin: 10px auto 0;
    }

    /* ── CALCULATOR ── */
    .calculator-section {
      padding: 2rem 2rem 3rem;
      max-width: 960px;
      margin: 0 auto;
    }

    .calc-box {
      background: var(--white);
      border: 1px solid #d1fae5;
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .calc-header {
      background: var(--green-dark);
      padding: 1.25rem 1.75rem;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .calc-header i { font-size: 22px; color: var(--gold); }

    .calc-header h3 {
      font-family: 'Teko', sans-serif;
      font-size: 22px;
      color: var(--white);
      font-weight: 500;
      letter-spacing: 0.5px;
    }

    .calc-header span {
      margin-right: auto;
      font-size: 12px;
      color: var(--green-pale);
    }

    .calc-body { padding: 1.75rem; }

    .rate-info {
      background: var(--green-pale);
      border-right: 4px solid var(--green-light);
      padding: 10px 16px;
      border-radius: 8px;
      margin-bottom: 1.5rem;
      font-size: 0.88rem;
      color: var(--green-dark);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .input-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 14px;
      margin-bottom: 1rem;
    }

    .form-group { display: flex; flex-direction: column; gap: 5px; }

    .form-group label {
      font-size: 0.82rem;
      color: var(--text-mid);
      font-weight: 600;
    }

    .form-group input,
    .form-group select {
      padding: 9px 12px;
      border: 1.5px solid #d1fae5;
      border-radius: 8px;
      font-family: 'Noto Nastaliq Urdu', serif;
      font-size: 0.9rem;
      color: var(--text-dark);
      background: var(--cream);
      transition: border-color 0.2s, box-shadow 0.2s;
      outline: none;
    }

    .form-group input:focus,
    .form-group select:focus {
      border-color: var(--green-light);
      box-shadow: 0 0 0 3px rgba(64,145,108,0.12);
      background: var(--white);
    }

    .btn-add {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 24px;
      background: var(--green-mid);
      color: var(--white);
      border: none;
      border-radius: 8px;
      font-family: 'Noto Nastaliq Urdu', serif;
      font-size: 0.95rem;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s;
      white-space: nowrap;
    }

    .btn-add:hover { background: var(--green-dark); transform: scale(1.02); }
    .btn-add:active { transform: scale(0.98); }

    /* summary cards */
    .summary-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 12px;
      margin: 1.5rem 0;
    }

    .metric-card {
      background: var(--cream);
      border: 1px solid #d1fae5;
      border-radius: var(--radius);
      padding: 1rem;
      text-align: center;
    }

    .metric-label {
      font-size: 0.78rem;
      color: var(--text-light);
      margin-bottom: 4px;
    }

    .metric-value {
      font-family: 'Teko', sans-serif;
      font-size: 1.7rem;
      font-weight: 600;
      color: var(--green-dark);
      letter-spacing: 0.5px;
    }

    .metric-value.gold { color: var(--gold-dark); }

    /* table */
    .table-wrapper {
      overflow-x: auto;
      border: 1px solid #d1fae5;
      border-radius: var(--radius);
      margin-top: 1rem;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.88rem;
      min-width: 560px;
    }

    thead {
      background: var(--green-dark);
      color: var(--white);
    }

    thead th {
      padding: 11px 14px;
      text-align: right;
      font-weight: 500;
      font-size: 0.82rem;
      white-space: nowrap;
    }

    tbody tr {
      border-bottom: 1px solid #d1fae5;
      transition: background 0.15s;
    }

    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: #f0fdf4; }

    tbody td {
      padding: 10px 14px;
      text-align: right;
      color: var(--text-dark);
    }

    .td-num {
      font-family: 'Teko', sans-serif;
      font-size: 1rem;
      letter-spacing: 0.4px;
    }

    .td-profit { color: var(--green-mid); font-weight: 600; }
    .td-total  { color: var(--gold-dark);  font-weight: 700; }

    tfoot tr { background: var(--green-pale); }

    tfoot td {
      padding: 10px 14px;
      text-align: right;
      font-weight: 700;
      color: var(--green-dark);
      font-size: 0.9rem;
    }

    .btn-del {
      background: none;
      border: none;
      cursor: pointer;
      color: #dc2626;
      font-size: 14px;
      padding: 4px 8px;
      border-radius: 6px;
      transition: background 0.15s;
    }

    .btn-del:hover { background: #fee2e2; }

    .empty-row td {
      text-align: center;
      padding: 2.5rem;
      color: var(--text-light);
      font-size: 0.9rem;
    }

    .btn-clear {
      margin-top: 1rem;
      padding: 8px 18px;
      background: none;
      border: 1px solid #dc2626;
      color: #dc2626;
      border-radius: 8px;
      font-family: 'Noto Nastaliq Urdu', serif;
      font-size: 0.85rem;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-clear:hover { background: #dc2626; color: var(--white); }

    /* ── FOOTER ── */
    footer {
      background: var(--green-dark);
      color: var(--green-pale);
      margin-top: 3rem;
    }

    .footer-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 2rem;
      padding: 3rem 2rem 2rem;
      max-width: 1000px;
      margin: 0 auto;
    }

    .footer-col h4 {
      font-family: 'Teko', sans-serif;
      font-size: 20px;
      color: var(--gold);
      margin-bottom: 1rem;
      letter-spacing: 0.5px;
    }

    .footer-col p {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
      font-size: 0.85rem;
    }

    .footer-col p i { color: var(--gold); width: 16px; }

    .footer-col iframe {
      border: none;
      border-radius: var(--radius);
      display: block;
      width: 100%;
      max-width: 320px;
    }

    .footer-bottom {
      border-top: 1px solid rgba(255,255,255,0.1);
      text-align: center;
      padding: 1rem 2rem;
      font-size: 0.8rem;
      color: rgba(255,255,255,0.5);
    }

    .footer-bottom strong { color: var(--gold); }

    /* ── SCROLL TO TOP ── */
    .scroll-top {
      position: fixed;
      bottom: 24px;
      left: 24px;
      width: 42px;
      height: 42px;
      background: var(--green-mid);
      color: var(--white);
      border: none;
      border-radius: 50%;
      font-size: 18px;
      cursor: pointer;
      display: none;
      align-items: center;
      justify-content: center;
      box-shadow: var(--shadow);
      transition: background 0.2s, transform 0.2s;
      z-index: 200;
    }

    .scroll-top:hover { background: var(--green-dark); transform: scale(1.1); }
    .scroll-top.visible { display: flex; }
  </style>
</head>

