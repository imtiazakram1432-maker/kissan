  <button class="scroll-top" id="scrollTop" onclick="window.scrollTo({top:0,behavior:'smooth'})" title="اوپر جائیں">
    <i class="fa-solid fa-arrow-up"></i>
  </button>

  <!-- ===== JS ===== -->
  <script>
    const RATE        = 60000;
    const CONVERSIONS = { acre: 1, marla: 1/160, kanal: 1/8, hectare: 2.47105 };
    const UNIT_LABELS = { acre: 'ایکڑ', marla: 'مرلہ', kanal: 'کنال', hectare: 'ہیکٹر' };

    let entries = [];
    let counter = 0;

    function pkr(n)    { return '₨\u202F' + Math.round(n).toLocaleString('en-PK'); }
    function num(n, d)  { return parseFloat(n.toFixed(d ?? 2)).toLocaleString('en-PK'); }

    function addEntry() {
      const name  = document.getElementById('ownerName').value.trim() || 'نامعلوم';
      const area  = parseFloat(document.getElementById('areaInput').value);
      const unit  = document.getElementById('unitSelect').value;
      const years = Math.max(1, parseInt(document.getElementById('yearsInput').value) || 1);

      if (!area || area <= 0) {
        alert('براہ کرم درست رقبہ درج کریں');
        document.getElementById('areaInput').focus();
        return;
      }

      counter++;
      const acres  = area * CONVERSIONS[unit];
      const annual = acres * RATE;
      const total  = annual * years;
      entries.push({ id: counter, name, area, unit, acres, years, annual, total });

      renderTable();
      document.getElementById('ownerName').value  = '';
      document.getElementById('areaInput').value  = '';
      document.getElementById('yearsInput').value = '1';
      document.getElementById('ownerName').focus();
    }

    function removeEntry(id) {
      entries = entries.filter(e => e.id !== id);
      renderTable();
    }

    function clearAll() {
      if (!confirm('کیا آپ واقعی سب اندراج حذف کرنا چاہتے ہیں؟')) return;
      entries = [];
      counter = 0;
      renderTable();
    }

    function renderTable() {
      const tbody  = document.getElementById('tableBody');
      const tfoot  = document.getElementById('tableFoot');
      const cards  = document.getElementById('summaryCards');
      const btnClr = document.getElementById('btnClear');

      if (entries.length === 0) {
        tbody.innerHTML = `<tr class="empty-row"><td colspan="8">
          <i class="fa-solid fa-seedling" style="font-size:1.4rem;color:#86efac;display:block;margin-bottom:6px;"></i>
          ابھی کوئی اندراج نہیں — اوپر رقبہ درج کریں
        </td></tr>`;
        tfoot.innerHTML   = '';
        cards.style.display  = 'none';
        btnClr.style.display = 'none';
        return;
      }

      cards.style.display  = 'grid';
      btnClr.style.display = 'inline-flex';

      tbody.innerHTML = entries.map(e => `
        <tr>
          <td style="color:var(--text-light);font-size:.8rem">${e.id}</td>
          <td>${e.name}</td>
          <td class="td-num">${num(e.area)} ${UNIT_LABELS[e.unit]}</td>
          <td class="td-num">${num(e.acres)}</td>
          <td class="td-num">${e.years}</td>
          <td class="td-num td-profit">${pkr(e.annual)}</td>
          <td class="td-num td-total">${pkr(e.total)}</td>
          <td><button class="btn-del" onclick="removeEntry(${e.id})" title="حذف کریں"><i class="fa-solid fa-xmark"></i></button></td>
        </tr>
      `).join('');

      const totalAcres  = entries.reduce((s, e) => s + e.acres,  0);
      const totalAnnual = entries.reduce((s, e) => s + e.annual, 0);
      const totalProfit = entries.reduce((s, e) => s + e.total,  0);
      const monthly     = totalAnnual / 12;

      if (entries.length > 1) {
        tfoot.innerHTML = `<tr>
          <td colspan="3" style="color:var(--green-mid);">مجموعی</td>
          <td class="td-num">${num(totalAcres)}</td>
          <td></td>
          <td class="td-num td-profit">${pkr(totalAnnual)}</td>
          <td class="td-num td-total">${pkr(totalProfit)}</td>
          <td></td>
        </tr>`;
      } else { tfoot.innerHTML = ''; }

      document.getElementById('smTotalAcres').textContent = num(totalAcres);
      document.getElementById('smAnnual').textContent     = pkr(totalAnnual);
      document.getElementById('smTotal').textContent      = pkr(totalProfit);
      document.getElementById('smMonthly').textContent    = pkr(monthly);
    }

    /* Enter key shortcut */
    ['ownerName','areaInput','yearsInput'].forEach(id => {
      document.getElementById(id).addEventListener('keydown', e => {
        if (e.key === 'Enter') addEntry();
      });
    });

    /* Scroll-to-top button */
    window.addEventListener('scroll', () => {
      document.getElementById('scrollTop').classList.toggle('visible', window.scrollY > 300);
    });
  </script>

